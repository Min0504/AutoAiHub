{
  "version": 2,
  "buildCommand": "vite build && esbuild api/index.src.ts --bundle --platform=node --format=cjs --external:@google/genai --external:express --external:dotenv --external:uuid --outfile=api/index.js",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" }
  ]
}
