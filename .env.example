# ─────────────────────────────────────────────────
# Groq AI
# ─────────────────────────────────────────────────
# Required for AI scenario builder, proposal generator, chatbot
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# ─────────────────────────────────────────────────
# Supabase — 리드 저장 (권장)
# ─────────────────────────────────────────────────
# 설정 방법:
#   1. https://supabase.com 에서 프로젝트 생성
#   2. supabase/schema.sql 의 SQL을 Supabase SQL Editor에서 실행
#   3. Settings > API 에서 URL과 service_role key 복사
#
# SUPABASE_URL 과 SUPABASE_SERVICE_KEY 가 없으면 ./data/leads.jsonl 로 폴백 저장됨
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ─────────────────────────────────────────────────
# Slack — 새 리드 알림 (선택)
# ─────────────────────────────────────────────────
# 설정 방법:
#   1. https://api.slack.com/apps 에서 앱 생성
#   2. Incoming Webhooks 활성화 후 채널 선택
#   3. Webhook URL 복사
#
# 없으면 알림 없이 조용히 저장만 됨
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# ─────────────────────────────────────────────────
# 기타
# ─────────────────────────────────────────────────
APP_URL="MY_APP_URL"

# Supabase 미사용 시 JSONL 저장 경로
LEADS_DIR="./data"
